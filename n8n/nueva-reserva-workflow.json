        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer REPLACE_WITH_YOUR_GHL_API_KEY"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Version",
              "value": "2021-07-28"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={\n  \"locationId\": \"REPLACE_WITH_YOUR_GHL_LOCATION_ID\",\n  \"firstName\": \"{{ $json.first_name }}\",\n  \"lastName\": \"{{ $json.last_name }}\",\n  \"email\": \"{{ $json.email }}\",\n  \"phone\": \"{{ $json.phone }}\",\n  \"customFields\": [\n    { \"key\": \"contact.fecha_checkin\", \"value\": \"{{ $json.fecha_checkin }}\" },\n    { \"key\": \"contact.fecha_checkout\", \"value\": \"{{ $json.fecha_checkout }}\" },\n    { \"key\": \"contact.nmero_de_noches\", \"value\": \"{{ $json.noches }}\" },\n    { \"key\": \"contact.nmero_de_personas\", \"value\": \"{{ $json.personas }}\" },\n    { \"key\": \"contact.total_a_pagar_\", \"value\": \"{{ $json.total }}\" },\n    { \"key\": \"contact.notas_de_la_reserva\", \"value\": \"{{ $json.notas }}\" }\n  ]\n}",
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "id": "http-crear-contacto-001",
      "name": "Crear/Actualizar Contacto GHL",
