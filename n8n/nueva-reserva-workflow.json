        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={\n  \"pipelineId\": \"REPLACE_WITH_YOUR_GHL_PIPELINE_ID\",\n  \"locationId\": \"REPLACE_WITH_YOUR_GHL_LOCATION_ID\",\n  \"name\": \"Reserva {{ $('Mapear Variables').item.json.fecha_checkin }} - {{ $('Mapear Variables').item.json.first_name }} {{ $('Mapear Variables').item.json.last_name }}\",\n  \"pipelineStageId\": \"REPLACE_WITH_YOUR_GHL_STAGE_NUEVA_RESERVA\",\n  \"contactId\": \"{{ $json.contact?.id || $json.id }}\",\n  \"monetaryValue\": {{ $('Mapear Variables').item.json.total }},\n  \"status\": \"open\"\n}",
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
