        "mode": "raw",
        "jsonOutput": "={\n  \"first_name\": \"{{ $json.body.first_name }}\",\n  \"last_name\": \"{{ $json.body.last_name }}\",\n  \"email\": \"{{ $json.body.email }}\",\n  \"phone\": \"{{ $json.body.phone }}\",\n  \"fecha_checkin\": \"{{ $json.body.fecha_checkin }}\",\n  \"fecha_checkout\": \"{{ $json.body.fecha_checkout }}\",\n  \"noches\": {{ $json.body.noches }},\n  \"personas\": {{ $json.body.personas }},\n  \"total\": {{ $json.body.total }},\n  \"sinpe\": \"{{ $json.body.sinpe }}\",\n  \"notas\": \"{{ $json.body.notas }}\",\n  \"status\": \"{{ $json.body.status }}\"\n}",
        "options": {}
      },
      "id": "set-nueva-001",
