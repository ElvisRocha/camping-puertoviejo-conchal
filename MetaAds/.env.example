# ============================================================
#  Camping Puerto Viejo Conchal — Variables de Entorno
#  Copiá este archivo como .env y completá los valores
#  ⚠️  NUNCA subas el .env a Git o lo compartas
# ============================================================

# ── Anthropic Claude ─────────────────────────────────────────
# Obtené tu API key en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXX

# ── Carpetas locales ─────────────────────────────────────────
# Carpeta donde están tus fotos crudas del camping
INPUT_FOLDER=./images

# Carpeta donde se guardarán las imágenes generadas para revisar
OUTPUT_FOLDER=./output

# ── Meta (Facebook + Instagram) ──────────────────────────────
# ID de tu Página de Facebook (número, ej: 123456789012345)
# Lo encontrás en: Facebook → tu Página → Acerca de → ID de página
FB_PAGE_ID=123456789012345

# Page Access Token (sigue la guía del README para obtenerlo)
# ⚠️  Este token expira — debés renovarlo periódicamente
FB_PAGE_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Instagram Business Account ID (número)
# Si no tenés Instagram Business, dejalo vacío y solo publicará en Facebook
# Guía para obtenerlo en el README
IG_ACCOUNT_ID=

# ── Log ──────────────────────────────────────────────────────
LOG_FILE=./output/publish_log.json

# ── Notificación por email (opcional) ────────────────────────
# Si querés recibir un email al publicar (requiere configuración SMTP extra)
NOTIFICATION_EMAIL=tu@email.com
